<?xml version="1.0" encoding="UTF-8"?>
<!-- 
    Page Object Model para Elementos Mobile (Appium)
    Armazena os seletores dos elementos da tela de Equipamentos no app mobile
-->
<elements>
    <!-- Botões Principais -->
    <button id="btn_novo_equipamento" 
            android="id=com.fast2mine:id/btn_novo_equipamento"
            ios="id=btnNovoEquipamento"
            description="Botão para cadastrar novo equipamento"/>
    
    <button id="btn_salvar" 
            android="id=com.fast2mine:id/btn_salvar"
            ios="id=btnSalvar"
            description="Botão para salvar equipamento"/>
    
    <button id="btn_cancelar" 
            android="id=com.fast2mine:id/btn_cancelar"
            ios="id=btnCancelar"
            description="Botão para cancelar operação"/>
    
    <!-- Campos de Entrada -->
    <input id="input_nome" 
           android="id=com.fast2mine:id/input_nome"
           ios="id=inputNome"
           description="Campo de entrada do nome do equipamento"/>
    
    <input id="input_tipo" 
           android="id=com.fast2mine:id/spinner_tipo"
           ios="id=pickerTipo"
           description="Seletor do tipo de equipamento"/>
    
    <input id="input_status" 
           android="id=com.fast2mine:id/spinner_status"
           ios="id=pickerStatus"
           description="Seletor do status do equipamento"/>
    
    <input id="input_localizacao" 
           android="id=com.fast2mine:id/input_localizacao"
           ios="id=inputLocalizacao"
           description="Campo de entrada da localização"/>
    
    <!-- Lista e Itens -->
    <list id="lista_equipamentos" 
          android="id=com.fast2mine:id/recycler_equipamentos"
          ios="id=tableViewEquipamentos"
          description="Lista de equipamentos cadastrados"/>
    
    <item id="item_equipamento" 
          android="xpath=//android.widget.TextView[@text='{nome}']"
          ios="xpath=//XCUIElementTypeCell[contains(@name, '{nome}')]"
          description="Item de equipamento na listagem"/>
    
    <!-- Mensagens -->
    <toast id="msg_sucesso" 
           android="xpath=//android.widget.Toast"
           ios="id=toastMessage"
           description="Mensagem de sucesso"/>
    
    <toast id="msg_erro" 
           android="xpath=//android.widget.Toast[@text]"
           ios="id=alertMessage"
           description="Mensagem de erro"/>
</elements>
