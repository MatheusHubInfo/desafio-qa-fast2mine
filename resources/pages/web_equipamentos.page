*** Settings ***
Documentation        Mapeamento de elementos (Locators) da tela de Equipamentos (Web).

*** Variables ***
# Seletores da Tela de Listagem e Busca
${WEB_INPUT_BUSCA}          id=search-equipment
${WEB_BTN_BUSCAR}           css=button.btn-search
${WEB_BTN_LIMPAR}           id=clear-filter
${WEB_TABELA_REGISTROS}     css=table.table-equipments
${WEB_ALERTA_NAO_ENCONTRADO}    css=.alert-not-found

# Seletores da Linha do Equipamento na Tabela
${WEB_TXT_NOME_EQUIP}       css=td.equipment-name
${WEB_TXT_STATUS_EQUIP}     css=td.equipment-status
${WEB_BTN_EDITAR}           css=button.btn-edit

# Seletores da Tela/Modal de Edição
${WEB_INPUT_NOME_EDIT}      id=edit-equipment-name
${WEB_SELECT_STATUS_EDIT}    id=edit-equipment-status
${WEB_BTN_SALVAR}           id=save-equipment
${WEB_MSG_VALIDACAO}        css=.invalid-feedback
${WEB_MSG_SUCESSO}          css=.toast-success
